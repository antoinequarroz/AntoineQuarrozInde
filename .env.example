# Resend — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email de réception des messages du formulaire de contact
CONTACT_EMAIL=info@antoinequarroz.ch

# Cloudflare Turnstile (anti-bot)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: restrict admin API access to a single Supabase user email
ADMIN_EMAIL=

# Public/default tenant slug for non-authenticated content reads
DEFAULT_ORGANIZATION_SLUG=
